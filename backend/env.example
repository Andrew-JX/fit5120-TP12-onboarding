# ============================================================
# FIT5120 TP12 Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
# Local example: postgresql://postgres:password@localhost:5432/fit5120_tp12
# Render example: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/fit5120_tp12

# Session Secret (generate a long random string)
SESSION_SECRET=replace_this_with_a_long_random_secret_string_at_least_32_chars

# OpenWeatherMap UV Index API Key
# Get free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Frontend URL (for CORS)
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# File Upload (local storage path)
UPLOAD_DIR=uploads
